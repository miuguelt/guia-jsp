# =========================================================================
# Configuración de entorno — FastAPI Inventario
# =========================================================================
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env
# =========================================================================

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventario_db

# JWT
SECRET_KEY=sena-adso-jwt-secret-key-2026-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Servidor
HOST=0.0.0.0
PORT=8000
RELOAD=true

# CORS (orígenes permitidos, separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
