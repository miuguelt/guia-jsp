# =========================================================================
# EJEMPLO .env — Guía JSP MVC
# =========================================================================
# Copiar como .env y ajustar valores para desarrollo local.
# ⚠️  NUNCA subir .env al repositorio (gitignorado)
# ⚠️  En Coolify las variables se configuran en la UI, no aquí
# =========================================================================
# Convenciones por lenguaje:
#   Java/JSP  → DATABASE_URL (JDBC), DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD
#   Python    → pydantic-settings lee .env automáticamente (python-dotenv / pydantic)
#   React/Vite → VITE_* (expuestas al bundle)
#   Flutter   → --dart-define en BUILD time (no .env en runtime)
# =========================================================================

# ===== PostgreSQL (compartido :5434 o local :5432) =====
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5434/inventario_db
DB_HOST=127.0.0.1
DB_PORT=5434
DB_NAME=inventario_db
DB_USER=postgres
DB_PASSWORD=postgres

# ===== FastAPI =====
SECRET_KEY=cambiar-esta-clave-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Frontend React =====
VITE_API_URL=http://localhost:8000/api

# ===== Frontend Flutter (build time) =====
# API_BASE_URL=http://localhost:8000/api
